    {
        "id": "e529d1a1cfcc8ef7",
        "type": "function",
        "z": "948f0b260d3f9fa4",
        "name": "Format ToF SQL",
        "func": "let bin_id = msg.payload.bin_id;\n\n// Safely handle if distance is out of range (null)\nlet distance_cm = msg.payload.distance_cm === null ? \"NULL\" : msg.payload.distance_cm;\n\n// Safely handle if NTP time failed (null). Fallback to database current time.\nlet recorded_at = msg.payload.recorded_at === null ? \"CURRENT_TIMESTAMP\" : `FROM_UNIXTIME(${msg.payload.recorded_at})`;\n\n// Build the SQL string and attach it to msg.topic for the MySQL node\nmsg.topic = `INSERT INTO fill_readings (bin_id, distance_cm, recorded_at) VALUES ('${bin_id}', ${distance_cm}, ${recorded_at});`;\n\n// Delete the payload to prevent MySQL node confusion\ndelete msg.payload;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
