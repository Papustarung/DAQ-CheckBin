    {
        "id": "477c1de9aabcd3b7",
        "type": "function",
        "z": "948f0b260d3f9fa4",
        "name": "JSON to SQL",
        "func": "// 1. Extract values from the API response\nconst current = msg.payload.current;\nconst lat = msg.payload.latitude;\nconst lon = msg.payload.longitude;\n\n// 2. Format the timestamp (Open-Meteo uses \"2026-03-24T09:00\")\n// We replace 'T' with a space to make it MySQL-friendly: \"2026-03-24 09:00\"\nconst formattedTime = current.time.replace(\"T\", \" \");\n\n// 3. Prepare the SQL query (added 'timestamp' column)\nmsg.topic = \"INSERT INTO weather_history (timestamp, temp_c, humidity_pct, precipitation_mm, weather_code, lat, lon) VALUES (?, ?, ?, ?, ?, ?, ?);\";\n\n// 4. Create the array of values (order must match the SQL query above)\nmsg.payload = [\n    formattedTime,           // Added this\n    current.temperature_2m,\n    current.relative_humidity_2m,\n    current.precipitation,\n    current.weather_code,\n    lat,\n    lon\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
